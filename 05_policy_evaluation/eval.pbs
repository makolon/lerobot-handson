#!/bin/bash
# =============================================================================
# eval.pbs  —  PBS job that runs lerobot-eval on a GH200 compute node
# -----------------------------------------------------------------------------
# Submit: source config.env && qsub 05_policy_evaluation/eval.pbs
#
# Miyabi PBS syntax (verified 2026-06-08): billing via -W group_list=, one GH200 via
# -l select=1 (GPU auto-allocated). Pass resource values at submit time.
# (no -v/-V: Miyabi rejects forwarding the submit env — the job sources config.env.)
# =============================================================================

#PBS -N lerobot_eval
#PBS -j oe
# Submit example (same shape as 04_policy_training/train.pbs):
#   qsub -q "$QUEUE_NAME" -W group_list="$GROUP" -l select=1 \
#        -l walltime="$WALLTIME" 05_policy_evaluation/eval.pbs

set -euo pipefail
cd "${PBS_O_WORKDIR:-$(pwd)}"

if [[ -f config.env ]]; then
  # shellcheck disable=SC1091
  source config.env
fi

# --- fail-fast ---
: "${APPTAINER_IMAGE:?APPTAINER_IMAGE unset (config.env)}"
: "${OUTPUT_DIR:?OUTPUT_DIR unset}"
: "${HF_HOME:?HF_HOME unset}"

# HF_HOME must exist on the host: apptainer's --bind fails if the source path is missing.
mkdir -p "${OUTPUT_DIR}" "${HF_HOME}"

# Compute nodes have internet; the pre-staged cache is used for speed/reproducibility.
export HF_HOME

if [[ -n "${APPTAINER_MODULE:-}" && "${APPTAINER_MODULE}" != "<"* ]]; then
  module load "${APPTAINER_MODULE}"
fi

apptainer exec --nv \
  --home "${OUTPUT_DIR}" \
  --bind "${OUTPUT_DIR}:${OUTPUT_DIR}" \
  --bind "${HF_HOME}:${HF_HOME}" \
  --env "HF_HOME=${HF_HOME}" \
  "${APPTAINER_IMAGE}" \
  bash 05_policy_evaluation/eval.sh
