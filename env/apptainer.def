# =============================================================================
# apptainer.def  —  LeRobot container definition for GH200 (aarch64)
# -----------------------------------------------------------------------------
# Assumptions:
#   - Miyabi compute nodes are NVIDIA GH200 (Grace Hopper) = aarch64 arch.
#     x86-only wheels/instructions will not work.
#   - The base is an aarch64-capable NGC PyTorch container (multi-arch tag).
#   - lerobot is pinned to v0.5.1 (keep in sync with the tag/commit in README).
#
# See env/build_image.sh for how to build (apptainer build on the login node).
#
# TODO(miyabi): confirm available NGC tags / aarch64 dependency resolution on the
#               real system.
# =============================================================================

Bootstrap: docker
# NGC PyTorch container (multi-arch: pulls the arm64 / SBSA build on GH200/aarch64).
# Used for its CUDA 12.9 / Python 3.12 base + system libs; torch itself is replaced in
# %post by an explicit cu128 wheel pair (see the note there). 25.06 ships torch 2.8.0a0
# with torchvision *0.22.0a0* — a pre-release below lerobot's >=0.22 floor — so its
# bundled pair can't be kept as-is; we install our own CUDA pair instead.
# Verified 2026-06-08 against lerobot 0.5.1 metadata + NGC release notes.
From: nvcr.io/nvidia/pytorch:25.06-py3

%labels
    Maintainer lerobot-handson
    LeRobotVersion v0.5.1
    LeRobotCommit 1396b9fab7aecddd10006c33c47a487ffdcb54b4
    Arch aarch64

%post
    set -eux

    # The NGC base bakes in PIP_CONSTRAINT=/etc/pip/constraint.txt, which pins
    # torch/torchvision to its bundled (incompatible) versions and is inherited by
    # every pip call here. Clear it so we control torch ourselves; the lerobot step
    # below sets its own PIP_CONSTRAINT to pin the CUDA pair we install.
    unset PIP_CONSTRAINT

    # ---- System GL/EGL stack for headless MuJoCo (MUJOCO_GL=egl) rendering ----
    # The NGC base is compute-only and has NO GL/EGL libraries. LIBERO/robosuite render
    # via MuJoCo's EGL backend, and PyOpenGL needs libglvnd's libEGL.so.1 present in the
    # IMAGE (the NVIDIA *vendor* lib libEGL_nvidia is bound in at runtime by
    # `apptainer --nv`). Without these, importing the env dies at `_p.PLATFORM.EGL is
    # None`. Verified the package set resolves on Ubuntu 24.04/noble arm64 (2026-06-10).
    apt-get update
    apt-get install -y --no-install-recommends \
        libglvnd0 libgl1 libglx0 libegl1 libgles2 libopengl0 \
        libegl-mesa0 libgl1-mesa-dri
    rm -rf /var/lib/apt/lists/*
    # Register the NVIDIA EGL vendor so libglvnd dispatches to the driver's libEGL
    # (bound in by --nv) instead of mesa. Harmless if --nv also provides this file.
    mkdir -p /usr/share/glvnd/egl_vendor.d
    printf '%s\n' '{"file_format_version":"1.0.0","ICD":{"library_path":"libEGL_nvidia.so.0"}}' \
        > /usr/share/glvnd/egl_vendor.d/10_nvidia.json

    python -m pip install --no-cache-dir --upgrade pip

    # ---- CUDA torch/torchvision (aarch64 / SBSA) ----
    # Install a MATCHED GPU build pair from PyTorch's official cu128 wheel index.
    # torch 2.10.0 + torchvision 0.25.0 are aarch64 CUDA wheels (verified available on
    # download.pytorch.org/whl/cu128) and satisfy lerobot 0.5.1's torch>=2.7,<2.11 and
    # torchvision>=0.22,<0.26. This REPLACES the NGC base's bundled torch.
    #   Why not just keep the NGC base torch? 25.06 ships torch 2.8.0a0 *paired with
    #   torchvision 0.22.0a0* — a pre-release that sorts BELOW lerobot's >=0.22 floor,
    #   so pip can't keep it; and 25.01's torch 2.6.0a0 is <2.7. An explicit cu128 pair
    #   sidesteps both NGC quirks. The cu128 wheels bundle their own CUDA 12.8 runtime
    #   (works on GH200 sm_90 regardless of the base image's CUDA version).
    # Verified 2026-06-08 on a GH200 node (mg0010, driver 595.58.03): the cu128 wheels
    # run with cuda available=True, device "NVIDIA GH200 120GB" (sm_90). If a future
    # driver is too old for CUDA 12.8, switch the index to cu126 + a matching pair.
    pip install --no-cache-dir --index-url https://download.pytorch.org/whl/cu128 \
        torch==2.10.0 torchvision==0.25.0

    # Pin the now-installed CUDA builds so the lerobot install can't pull CPU wheels.
    python - > /tmp/torch-constraints.txt <<'PY'
import torch, torchvision
print(f"torch=={torch.__version__}")
print(f"torchvision=={torchvision.__version__}")
PY
    echo "[def] pinned CUDA builds:"; cat /tmp/torch-constraints.txt

    # ---- Fix the broken cmake shim (needed to build egl_probe in [libero]) ----
    # The NGC base ships /usr/local/bin/cmake as a PYTHON shim (`from cmake import
    # cmake`). The lerobot[libero] extra pulls hf-egl-probe/egl_probe, which compile a
    # C++ EGL-probe with CMake. Under pip's PEP517 build isolation, that shim inherits
    # pip's PYTHONPATH (pointing at the isolated build overlay, which has no `cmake`
    # module), so `cmake --version` dies with ModuleNotFoundError and the wheel build
    # fails. Point cmake at the native binary the `cmake` pip package already bundles —
    # a real ELF, immune to PYTHONPATH. Verified 2026-06-10 on the GH200 base image.
    CMAKE_NATIVE="$(python -c 'import cmake, os; print(os.path.join(os.path.dirname(cmake.__file__), "data", "bin", "cmake"))')"
    test -x "${CMAKE_NATIVE}"
    ln -sf "${CMAKE_NATIVE}" /usr/local/bin/cmake
    echo "[def] cmake -> ${CMAKE_NATIVE}"; PYTHONPATH=/nonexistent cmake --version | head -1

    # ---- Install LeRobot at the pinned commit ----
    # Extras are policy/sim dependencies:
    #   [aloha]  -> ALOHA sim + gym-aloha
    #   [libero] -> LIBERO eval suite. On Linux this pulls `hf-libero` (HF-packaged
    #               LIBERO that provides the `libero` python module), plus
    #               transformers/scipy. hf-libero is an sdist but pure-Python; its
    #               native deps (mujoco, robosuite 1.4.0, opencv) ship aarch64 wheels,
    #               so it builds on GH200. Required by 05_policy_evaluation (eval.sh
    #               defaults to the libero_object suite). Verified 2026-06-10 against
    #               lerobot 0.5.1 metadata (extra "libero" -> hf-libero>=0.1.3,<0.2.0).
    PIP_CONSTRAINT=/tmp/torch-constraints.txt pip install --no-cache-dir \
        "lerobot[aloha,libero] @ git+https://github.com/huggingface/lerobot.git@v0.5.1"

    # Fail the build LOUDLY if torch lost its CUDA build (e.g. a future base too old
    # for the constraint). Far better than shipping a silently CPU-only image.
    python -c "import torch; assert torch.version.cuda, 'torch is CPU-only: '+torch.__version__; print('[def] CUDA torch OK:', torch.__version__, 'cuda', torch.version.cuda)"

    # ---- Pre-bake LIBERO config + assets for offline, non-interactive use ----
    # LIBERO is installed above via lerobot[libero] (hf-libero), but its package
    # __init__ has two runtime traps that must be defused at build time (the login
    # node has internet; the compute nodes do NOT):
    #   1. On first import, if config.yaml is missing, it calls input() to ask about a
    #      custom dataset path — an interactive prompt that throws EOFError in a batch
    #      job. It also does os.makedirs(~/.libero), which fails on the read-only image.
    #   2. get_assets_path() downloads the mesh/scene assets from the Hub the first time
    #      any env is built (~/.cache/libero/assets) — impossible offline.
    # Fix both: pin LIBERO_CONFIG_PATH to a fixed in-image dir with a pre-written
    # config.yaml (so runtime imports skip the makedirs AND the input()), and snapshot
    # the asset repo into the package-local assets/ dir, which get_assets_path() returns
    # directly when it exists (no network at runtime). Verified 2026-06-10.
    export LIBERO_CONFIG_PATH=/opt/libero
    mkdir -p "${LIBERO_CONFIG_PATH}"
    # 'n' answers the "custom dataset path?" prompt; writes /opt/libero/config.yaml.
    echo n | python -c "import libero.libero; print('[def] wrote', __import__('os').path.join('${LIBERO_CONFIG_PATH}','config.yaml'))"
    HF_HUB_DISABLE_XET=1 python - <<'PY'
import os
from huggingface_hub import snapshot_download
import libero.libero
dest = os.path.join(os.path.dirname(libero.libero.__file__), "assets")
snapshot_download(repo_id="lerobot/libero-assets", repo_type="dataset", local_dir=dest)
# sanity: the dirs get_assets_path()/object loaders expect must now exist locally
need = ["articulated_objects", "stable_scanned_objects", "turbosquid_objects", "stable_hope_objects"]
missing = [d for d in need if not os.path.isdir(os.path.join(dest, d))]
assert not missing, f"libero assets incomplete, missing: {missing}"
print("[def] libero assets baked into", dest)
PY

    # ---- Force a single, headless OpenCV (drop the libxcb GUI dependency) ----
    # lerobot pins opencv-python-headless; hf-libero/robosuite pin opencv-python. pip
    # installs BOTH into the same cv2/ dir, and the non-headless build links libxcb.so.1
    # (absent in this headless image) so `import cv2` -> ImportError, which kills the
    # whole eval import chain (robosuite imports cv2). robosuite only needs cv2's API,
    # not its GUI windows, so collapse to the headless build: purge every opencv variant
    # AND the shared cv2/ dir (a half-removed dir otherwise breaks the reinstall), then
    # install only headless. Verified 2026-06-10: cv2 then imports with no libxcb.
    SP="$(python -c 'import lerobot, os; print(os.path.dirname(os.path.dirname(lerobot.__file__)))')"
    pip uninstall -y opencv-python opencv-python-headless opencv-contrib-python opencv-contrib-python-headless || true
    rm -rf "${SP}/cv2" "${SP}"/opencv_python* "${SP}"/opencv_contrib*
    pip install --no-cache-dir opencv-python-headless
    python -c "import cv2; print('[def] cv2 headless', cv2.__version__)"

    # W&B / HF CLI (used by training and pre-download)
    pip install --no-cache-dir wandb "huggingface_hub[cli]"

    # Notebook + plotting for 02_imitation_learning/explore.ipynb
    pip install --no-cache-dir matplotlib jupyterlab

%environment
    # In-container default. Actual offline control is exported by the PBS script.
    export PYTHONUNBUFFERED=1
    # Point LIBERO at the in-image config baked in %post so imports are non-interactive
    # and never try to write under a read-only HOME. Assets resolve from the package's
    # own assets/ dir (also baked in %post), so no Hub access is needed at runtime.
    export LIBERO_CONFIG_PATH=/opt/libero

%runscript
    exec "$@"

%test
    set -e
    # No GPU at build time, so assert the CUDA *build* is present (not availability).
    python -c "import torch; assert torch.version.cuda, 'CPU-only torch!'; print('torch', torch.__version__, 'cuda', torch.version.cuda)"
    python -c "import lerobot; print('lerobot OK')"
    # LIBERO must import non-interactively against the baked config (set it explicitly
    # in case %test does not source %environment), and its assets must resolve LOCALLY
    # with the Hub disabled — proving the eval works on the offline compute nodes.
    export LIBERO_CONFIG_PATH=/opt/libero
    HF_HUB_OFFLINE=1 python -c "from libero.libero import benchmark, get_libero_path, get_assets_path; import os; ap=get_assets_path(); assert os.path.isdir(os.path.join(ap,'turbosquid_objects')), 'libero assets not baked: '+ap; print('libero OK; assets', ap); print('suites', list(benchmark.get_benchmark_dict().keys())[:3])"
    # cv2 must be the headless build (no libxcb), and libEGL must be present so MuJoCo's
    # EGL renderer can load at runtime under --nv (actual rendering needs a GPU node).
    python -c "import cv2; print('cv2', cv2.__version__)"
    python -c "import ctypes.util; lib=ctypes.util.find_library('EGL'); assert lib, 'libEGL.so.1 missing from image'; print('libEGL OK:', lib)"
