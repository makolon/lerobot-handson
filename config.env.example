# =============================================================================
# config.env.example  —  template for the day-of variable values of lerobot-handson
# -----------------------------------------------------------------------------
# Usage:
#   cp config.env.example config.env
#   $EDITOR config.env        # fill in the values below
#   source config.env         # every script assumes these variables are set
#
# config.env is git-ignored (do not commit it).
#
# NOTE: the Miyabi/PBS values below were filled in against the live Miyabi-G
#       (GH200) login node on 2026-06-08 (`qstat --rsc`, `qstat --limit`,
#       `qsub --help`, `module avail`). The scheduler is PBS Pro, but Miyabi sets
#       the project with `-W group_list=<project>` (it REJECTS PBS Pro's `-P`),
#       plus `-q <queue>` and `-l select=<N>`. Still re-check on the day in case queue
#       names / your project allocation changed. The HF dataset and W&B project below
#       now default to the shared LIBERO hands-on setup (pre-staged in the share), so a
#       fresh `source config.env` runs as-is. Only HF_USER, WANDB_ENTITY and the eval
#       CKPT_REPO stay optional per-user / day-of values — see each comment below.
# =============================================================================

# ----- Miyabi / PBS scheduler ----------------------------------------------
# Verified live on Miyabi-G (GH200). Queues (`qstat --rsc` / queue limits):
#   short-g         1-8 nodes, walltime <= 08:00:00  -> batch training (use this)
#   debug-g         1-16 nodes, walltime <= 00:30:00 -> quick debugging
#   small-g         1-16 nodes, walltime <= 48:00:00 -> long runs (regular-g)
#   interact-g_n1   1 node,     walltime <= 02:00:00 -> interactive single node
export QUEUE_NAME="short-g"
export QUEUE_NAME_INTERACTIVE="interact-g"
export GROUP="gw13"
export WALLTIME="01:30:00"   # within the hands-on slot; fits short-g (<=08:00:00)

# Resources to request. Each Miyabi-G node is one GH200 (1 GPU/node).
# Submitted as: qsub -q "$QUEUE_NAME" -W group_list="$GROUP" -l select=${NUM_NODES} ...
export NUM_GPUS="1"
export NUM_NODES="1"

# ----- Apptainer / container -----------------------------------------------
# The .sif is SHARED: the organizer builds it ONCE into the shared area (see
# env/build_image.sh + MAINTAINER.md) and everyone just reads it — no per-person
# 15 GB build. The path (APPTAINER_IMAGE) is defined under "Shared storage" below.
export APPTAINER_MODULE="apptainer/1.3.5"

# ----- Shared storage / paths ----------------------------------------------
# Everything heavy lives on /work, NOT on your small (~24 GB) personal quota. Two tiers:
#   SHARED_DIR : staged ONCE by the organizer, READ by everyone (image, dataset,
#                backbone, HF cache). Readable offline on the compute nodes.
#   USER_DIR   : YOUR personal writable area UNDER the share (checkpoints, eval
#                output, W&B, the container's HOME). Auto-created below.
export SHARED_DIR="/work/gw13/share/handson"
export USER_DIR="${SHARED_DIR}/${USER:-$(id -un)}"

# --- shared, read-only (organizer stages these once; see MAINTAINER.md) ---
export APPTAINER_IMAGE="${SHARED_DIR}/images/lerobot-v0.5.1.sif"  # built once, read by all
export LIBERO_ROOT="${SHARED_DIR}/libero"   # LIBERO LeRobotDataset (~33 GB, read-only)
export TORCH_HOME="${SHARED_DIR}/torch"     # ACT ResNet18 ImageNet backbone cache
export DATA_DIR="${SHARED_DIR}/data"        # (generic train.sh path) shared dataset area

# --- your personal, writable outputs (checkpoints, eval, W&B) ---
export OUTPUT_DIR="${USER_DIR}/outputs"     # training artifacts (checkpoints, etc.)

# Create your personal area (the share is group-writable + sticky; you own this dir).
mkdir -p "${USER_DIR}" "${OUTPUT_DIR}"

# ----- Hugging Face ---------------------------------------------------------
# Compute nodes HAVE internet, but we pre-stage repos ONCE in the shared HF cache
# (env/predownload_hf.sh + the download_*.sh helpers) so every job reads the SAME
# files quickly and reproducibly instead of each person re-downloading.
export HF_HOME="${SHARED_DIR}/hf_home"      # shared HF cache (read; pre-staged repos)
# Loading a LeRobotDataset WRITES an arrow cache + lock files under the datasets cache.
# The shared HF_HOME is READ-ONLY for non-owners, so point the datasets cache at YOUR
# writable area (otherwise dataset loads die with "Read-only file system: .../hf_home"):
export HF_DATASETS_CACHE="${USER_DIR}/hf_datasets"
export HF_USER=""   # your HF username — only needed if you PUSH (03 convert / push_to_hub).
# Dataset repo (LeRobotDataset v3 format). The shared LIBERO dataset is staged as a
# LOCAL dir ($LIBERO_ROOT), so pass --dataset.root=$LIBERO_ROOT to train/read it
# (resolves instantly from disk and avoids a 33 GB re-download per person).
export DATA_REPO="HuggingFaceVLA/libero"
# Checkpoint to EVALUATE (step 05). The hands-on normally evaluates YOUR OWN trained
# checkpoint via POLICY_PATH (see 05_policy_evaluation/eval.sh), so this can stay empty.
# Set it to a LIBERO policy repo_id only if you pre-downloaded one (env/predownload_hf.sh).
export CKPT_REPO=""
# Raw LIBERO .hdf5 for the §3 conversion exercise. Stage it once on the login node with
# 03_dataset_conversion/download_libero_hdf5.py, then paste the printed path here:
export LIBERO_TASK_HDF5=""
# Only needed if you push_to_hub (optional). Leave unset for read-only use.
# export HF_TOKEN="<TODO: write token (only if you push)>"

# ----- Weights & Biases (shared project; compute nodes HAVE internet) ------
# Compute nodes can reach wandb.ai, so runs log LIVE to the shared project. Live logging
# needs your API key available IN the job, so paste WANDB_API_KEY below (W&B website ->
# Settings -> API keys). If you leave it empty, the train/eval scripts fall back to
# OFFLINE mode automatically (runs land in $WANDB_DIR/wandb/offline-run-*; upload later
# from anywhere with `wandb sync "$WANDB_DIR/wandb/"offline-run-*`).
export WANDB_PROJECT="lerobot-handson"
# Entity (team/org). Leave UNSET unless you have a shared team — the wandb SDK rejects a
# non-empty placeholder (':' '/' spaces). `unset` also clears a stale value on re-source.
unset WANDB_ENTITY
export WANDB_MODE="online"                # live logging (scripts fall back to offline if no key)
export WANDB_API_KEY=""                   # paste your W&B key for LIVE logging; empty -> offline
export WANDB_DIR="${OUTPUT_DIR}"          # where offline runs land if WANDB_API_KEY is empty

# ----- Training hyperparameters (fallback defaults: "make it flow" in 105 min) -----
export POLICY_TYPE="act"          # act | diffusion (VLAs are heavy, so default to the light one)
export TRAIN_STEPS="2000"         # meant to finish quickly. Increase for real runs
export BATCH_SIZE="8"             # conservative to avoid OOM. Tune on real GH200
export JOB_NAME="handson_${POLICY_TYPE}"
