# =============================================================================
# config.env.example  —  lerobot-handson の可変値テンプレート
# -----------------------------------------------------------------------------
# 使い方:
#   cp config.env.example config.env
#   $EDITOR config.env        # 下の値を埋める
#   source config.env         # 各スクリプトはこの変数を前提に動く
#
# config.env は .gitignore 済み（コミットしないこと）。
# <TODO: ...> のプレースホルダは「動くふり」の捏造値ではなく、
# 実環境（Miyabi公式マニュアル / 当日配布情報）で必ず確認して置き換える。
# =============================================================================

# ----- Miyabi / PBS スケジューラ -------------------------------------------
# TODO(miyabi): 以下4つは JCAHPC/Miyabi 公式マニュアルで要確認。スケジューラは
#               PBS系（qsub/qstat/qdel）を仮定しているが、書式も含め未検証。
export QUEUE_NAME="<TODO: 公式マニュアルで確認 (GH200計算ノード用キュー名)>"
export QUEUE_NAME_INTERACTIVE="<TODO: 公式マニュアルで確認 (対話/デバッグ用キュー名)>"
export GROUP="<TODO: 公式マニュアルで確認 (課金グループ/プロジェクト番号)>"
export WALLTIME="01:30:00"   # ハンズオン枠に収まる範囲。TODO(miyabi): 上限を要確認

# 確保する資源。TODO(miyabi): -l select=... の書式は Miyabi の仕様で要確認
export NUM_GPUS="1"
export NUM_NODES="1"

# ----- Apptainer / コンテナ ------------------------------------------------
# ログインノードでビルドしたイメージ（env/build_image.sh 参照）の絶対パス
export APPTAINER_IMAGE="<TODO: ビルド済み .sif の絶対パス>"
# TODO(miyabi): Apptainer/Singularity を使うための module 名を要確認
export APPTAINER_MODULE="<TODO: 例 'singularitypro' など。公式マニュアルで確認>"

# ----- 共有ストレージ / パス ------------------------------------------------
# 計算ノードからも見える共有領域。bind マウント対象になる。
export SHARED_DIR="<TODO: 共有領域の絶対パス (例 /work/<group>/<user>)>"
export DATA_DIR="${SHARED_DIR}/data"        # データセットの実体置き場
export OUTPUT_DIR="${SHARED_DIR}/outputs"   # 学習成果物（checkpoint等）

# ----- Hugging Face ---------------------------------------------------------
# 計算ノードはオフライン前提。ログインノードで事前DLし、共有領域を HF_HOME に。
export HF_HOME="${SHARED_DIR}/hf_home"      # HF キャッシュ（共有領域を指す）
export HF_USER="<TODO: あなたの HF ユーザ名 (push する場合)>"
# 事前DL/学習で使うデータセット repo（LeRobotDataset 形式 v3）
export DATA_REPO="<TODO: 例 lerobot/aloha_sim_insertion_human など>"
# 評価で使う配布済みチェックポイント repo
export CKPT_REPO="<TODO: 例 lerobot/act_aloha_sim_insertion_human など>"
# push_to_hub する場合のみ必要（任意）。read-only 運用なら未設定でよい。
# export HF_TOKEN="<TODO: 書き込みトークン (push する場合のみ)>"

# ----- Weights & Biases (共有) ----------------------------------------------
# 成果共有は git ではなく共有 W&B が担う。全員で同じ project/entity を使う。
export WANDB_PROJECT="<TODO: 共有W&Bプロジェクト名 (当日配布)>"
export WANDB_ENTITY="<TODO: 共有W&B entity/team名 (当日配布)>"
# export WANDB_API_KEY="<TODO: 各自のAPIキー (wandb login で入れてもよい)>"
# 計算ノードがオフラインなら offline + 後段 sync が必要な場合がある。
# TODO(miyabi): 計算ノードから wandb.ai へ到達可能か要確認。不可なら下を有効化。
# export WANDB_MODE="offline"

# ----- 学習ハイパラ（フォールバック既定: 105分内に「流れる」体験用）---------
# 既定は軽量ポリシー + 少ステップ。詳細は 03_train/train.sh 参照。
export POLICY_TYPE="act"          # act | diffusion （VLAは重いので既定は軽い方）
export TRAIN_STEPS="2000"         # 短時間で完走する想定。本番は増やす
export BATCH_SIZE="8"             # OOM 回避の保守値。GH200実機で調整可
export JOB_NAME="handson_${POLICY_TYPE}"
