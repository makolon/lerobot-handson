# =============================================================================
# config.env.example  —  template for the day-of variable values of lerobot-handson
# -----------------------------------------------------------------------------
# Usage:
#   cp config.env.example config.env
#   $EDITOR config.env        # fill in the values below
#   source config.env         # every script assumes these variables are set
#
# config.env is git-ignored (do not commit it).
# The <TODO: ...> placeholders are NOT fake "looks like it works" values; verify
# them on the real system (Miyabi official manual / day-of handout) and replace them.
# =============================================================================

# ----- Miyabi / PBS scheduler ----------------------------------------------
# TODO(miyabi): confirm the following four against the JCAHPC/Miyabi official
#               manual. We assume a PBS-family scheduler (qsub/qstat/qdel), but
#               that — including the syntax — is unverified.
export QUEUE_NAME="<TODO: confirm in official manual (GH200 compute queue name)>"
export QUEUE_NAME_INTERACTIVE="<TODO: confirm in official manual (interactive/debug queue name)>"
export GROUP="<TODO: confirm in official manual (billing group / project number)>"
export WALLTIME="01:30:00"   # within the hands-on slot. TODO(miyabi): confirm the cap

# Resources to request. TODO(miyabi): confirm the -l select=... syntax for Miyabi
export NUM_GPUS="1"
export NUM_NODES="1"

# ----- Apptainer / container -----------------------------------------------
# Absolute path of the image built on the login node (see env/build_image.sh)
export APPTAINER_IMAGE="<TODO: absolute path of the built .sif>"
# TODO(miyabi): confirm the module name needed to use Apptainer/Singularity
export APPTAINER_MODULE="<TODO: e.g. 'singularitypro'. Confirm in official manual>"

# ----- Shared storage / paths ----------------------------------------------
# A shared area visible from the compute nodes too. It becomes the bind-mount target.
export SHARED_DIR="<TODO: absolute path of the shared area (e.g. /work/<group>/<user>)>"
export DATA_DIR="${SHARED_DIR}/data"        # where the dataset lives
export OUTPUT_DIR="${SHARED_DIR}/outputs"   # training artifacts (checkpoints, etc.)

# ----- Hugging Face ---------------------------------------------------------
# Compute nodes are assumed offline. Pre-download on the login node, point HF_HOME
# at the shared area.
export HF_HOME="${SHARED_DIR}/hf_home"      # HF cache (points at the shared area)
export HF_USER="<TODO: your HF username (only if you push)>"
# Dataset repo (LeRobotDataset v3 format) used for pre-download / training
export DATA_REPO="<TODO: e.g. lerobot/aloha_sim_insertion_human>"
# Distributed checkpoint repo used for evaluation
export CKPT_REPO="<TODO: e.g. lerobot/act_aloha_sim_insertion_human>"
# Only needed if you push_to_hub (optional). Leave unset for read-only use.
# export HF_TOKEN="<TODO: write token (only if you push)>"

# ----- Weights & Biases (shared) -------------------------------------------
# Result sharing is via a shared W&B, not git. Everyone uses the same project/entity.
export WANDB_PROJECT="<TODO: shared W&B project name (day-of handout)>"
export WANDB_ENTITY="<TODO: shared W&B entity/team name (day-of handout)>"
# export WANDB_API_KEY="<TODO: your API key (or use `wandb login`)>"
# If the compute node is offline, you may need offline + a later sync.
# TODO(miyabi): confirm whether the compute node can reach wandb.ai. If not, enable below.
# export WANDB_MODE="offline"

# ----- Training hyperparameters (fallback defaults: "make it flow" in 105 min) -----
# Defaults are a lightweight policy + few steps. See 03_train/train.sh for details.
export POLICY_TYPE="act"          # act | diffusion (VLAs are heavy, so default to the light one)
export TRAIN_STEPS="2000"         # meant to finish quickly. Increase for real runs
export BATCH_SIZE="8"             # conservative to avoid OOM. Tune on real GH200
export JOB_NAME="handson_${POLICY_TYPE}"
