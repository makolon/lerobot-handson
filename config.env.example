# =============================================================================
# config.env.example  —  template for the day-of variable values of lerobot-handson
# -----------------------------------------------------------------------------
# Usage:
#   cp config.env.example config.env
#   $EDITOR config.env        # fill in the values below
#   source config.env         # every script assumes these variables are set
#
# config.env is git-ignored (do not commit it).
#
# NOTE: the Miyabi/PBS values below were filled in against the live Miyabi-G
#       (GH200) login node on 2026-06-08 (`qstat --rsc`, `qstat --limit`,
#       `qsub --help`, `module avail`). The scheduler is PBS Pro: `-P <project>`,
#       `-q <queue>`, `-l select=<N>`. Still re-check on the day in case queue
#       names / your project allocation changed. The remaining <TODO>s (HF repos,
#       W&B handout, HF username) are per-user / day-of values only you can supply.
# =============================================================================

# ----- Miyabi / PBS scheduler ----------------------------------------------
# Verified live on Miyabi-G (GH200). Queues (`qstat --rsc` / queue limits):
#   short-g         1-8 nodes, walltime <= 08:00:00  -> batch training (use this)
#   debug-g         1-16 nodes, walltime <= 00:30:00 -> quick debugging
#   small-g         1-16 nodes, walltime <= 48:00:00 -> long runs (regular-g)
#   interact-g_n1   1 node,     walltime <= 02:00:00 -> interactive single node
export QUEUE_NAME="short-g"
export QUEUE_NAME_INTERACTIVE="interact-g_n1"
export GROUP="gw13"
export WALLTIME="01:30:00"   # within the hands-on slot; fits short-g (<=08:00:00)

# Resources to request. Each Miyabi-G node is one GH200 (1 GPU/node).
# Submitted as: qsub -P "$GROUP" -q "$QUEUE_NAME" -l select=${NUM_NODES} ...
export NUM_GPUS="1"
export NUM_NODES="1"

# ----- Apptainer / container -----------------------------------------------
# Absolute path of the image built on the login node (see env/build_image.sh).
export APPTAINER_IMAGE="/work/gw13/${USER}/lerobot-handson/images/lerobot-v0.5.1.sif"
# Apptainer module verified available via `module avail` (singularity/4.2.1 also exists).
export APPTAINER_MODULE="apptainer/1.3.5"

# ----- Shared storage / paths ----------------------------------------------
# A shared area visible from the compute nodes too. It becomes the bind-mount target.
export SHARED_DIR="/work/gw13/share/handson"
export DATA_DIR="${SHARED_DIR}/data"        # where the dataset lives
export OUTPUT_DIR="${SHARED_DIR}/outputs"   # training artifacts (checkpoints, etc.)

# ----- Hugging Face ---------------------------------------------------------
# Compute nodes are assumed offline. Pre-download on the login node, point HF_HOME
# at the shared area.
export HF_HOME="${SHARED_DIR}/hf_home"      # HF cache (points at the shared area)
export HF_USER="<TODO: your HF username (only if you push)>"
# Dataset repo (LeRobotDataset v3 format) used for pre-download / training.
export DATA_REPO="<TODO: e.g. lerobot/aloha_sim_insertion_human>"
export CKPT_REPO="<TODO: e.g. lerobot/act_aloha_sim_insertion_human>"
# Only needed if you push_to_hub (optional). Leave unset for read-only use.
# export HF_TOKEN="<TODO: write token (only if you push)>"

# ----- Weights & Biases (shared, OFFLINE on Miyabi) ------------------------
# Miyabi compute nodes are offline, so W&B runs in OFFLINE mode: training writes the
# run locally (no network) and you PUSH it later from the LOGIN NODE (has internet).
# Everyone shares one project/entity (from the day-of handout).
#
#   after a job finishes, on the login node:
#     wandb login                                     # once (or export WANDB_API_KEY)
#     wandb sync "${OUTPUT_DIR}/wandb/"offline-run-*  # uploads the run(s)
#
export WANDB_PROJECT="<TODO: shared W&B project name (day-of handout)>"
export WANDB_ENTITY="<TODO: shared W&B entity/team name (day-of handout)>"
export WANDB_MODE="offline"               # log locally on the compute node; sync later
export WANDB_DIR="${OUTPUT_DIR}"          # offline runs -> ${OUTPUT_DIR}/wandb/offline-run-*
# The API key is only needed at SYNC time (login node), NOT during the offline run:
# export WANDB_API_KEY="<TODO: your API key (day-of handout)>"

# ----- Training hyperparameters (fallback defaults: "make it flow" in 105 min) -----
export POLICY_TYPE="act"          # act | diffusion (VLAs are heavy, so default to the light one)
export TRAIN_STEPS="2000"         # meant to finish quickly. Increase for real runs
export BATCH_SIZE="8"             # conservative to avoid OOM. Tune on real GH200
export JOB_NAME="handson_${POLICY_TYPE}"
