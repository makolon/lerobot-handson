#!/bin/bash
# =============================================================================
# train.pbs  —  PBS job that runs lerobot-train on a GH200 compute node
# -----------------------------------------------------------------------------
# Submit: source config.env && qsub 04_train/train.pbs
#
# Note: #PBS directives do not expand shell variables. So resource values are not
#       hard-coded here; instead pass config.env values via -v at submit time, or
#       override them with qsub arguments (see "submit example" below). This keeps
#       day-of values from being baked into the script.
#
# Miyabi PBS syntax (verified 2026-06-08 on Miyabi-G): billing project is passed with
# -W group_list=<GROUP> (NOT PBS Pro's -P, which Miyabi rejects). One GH200 node is
# requested with -l select=1; that node's GPU is allocated automatically (the job's
# Resource_List shows ngpus=1, ncpus=72, mem=100gb) — no :ngpus= needed.
# =============================================================================

#PBS -N lerobot_train
#PBS -j oe
# The following are passed at submit time (not hard-coded, so day-of values stay out
# of git):
#   -q <QUEUE_NAME>            e.g. short-g
#   -W group_list=<GROUP>      e.g. gw13
#   -l select=<NUM_NODES>      1 node = 1 GH200 (GPU auto-allocated)
#   -l walltime=<WALLTIME>     e.g. 01:30:00
#
# Recommended usage: don't hard-code the above; pass values at submit time.
#   Submit example:
#     qsub -q "$QUEUE_NAME" -W group_list="$GROUP" \
#          -l select=${NUM_NODES} \
#          -l walltime=${WALLTIME} \
#          -v ALL \
#          04_train/train.pbs

set -euo pipefail

# PBS may not start in the submit CWD. Move to the repo root.
cd "${PBS_O_WORKDIR:-$(pwd)}"

# --- load config.env (fallback for values not passed via -v ALL) ---
if [[ -f config.env ]]; then
  # shellcheck disable=SC1091
  source config.env
fi

# --- fail-fast: required variables ---
: "${APPTAINER_IMAGE:?APPTAINER_IMAGE unset (config.env)}"
: "${DATA_DIR:?DATA_DIR unset}"
: "${OUTPUT_DIR:?OUTPUT_DIR unset}"
: "${HF_HOME:?HF_HOME unset}"

# HF_HOME must exist on the host: apptainer's --bind fails if the source path is missing.
mkdir -p "${OUTPUT_DIR}" "${HF_HOME}"

# --- environment for the offline compute node ---
# Compute nodes have no external network. HF uses only the pre-downloaded cache.
export HF_HUB_OFFLINE=1
export HF_HOME

# Apptainer module (if needed)
# TODO(miyabi): confirm the Apptainer/Singularity module name
if [[ -n "${APPTAINER_MODULE:-}" && "${APPTAINER_MODULE}" != "<"* ]]; then
  module load "${APPTAINER_MODULE}"
fi

# --- run train.sh inside the container ---
# --nv     : pass the GPU through
# --bind   : make data / output / HF cache visible inside the container (important).
#            Forgetting this causes FileNotFoundError (see challenges/debug/broken_03).
apptainer exec --nv \
  --bind "${DATA_DIR}:${DATA_DIR}" \
  --bind "${OUTPUT_DIR}:${OUTPUT_DIR}" \
  --bind "${HF_HOME}:${HF_HOME}" \
  --env HF_HUB_OFFLINE=1 \
  --env "HF_HOME=${HF_HOME}" \
  "${APPTAINER_IMAGE}" \
  bash 03_train/train.sh
