#!/bin/bash
# =============================================================================
# eval.pbs  —  PBS job that runs lerobot-eval on a GH200 compute node
# -----------------------------------------------------------------------------
# Submit: source config.env && qsub 04_eval/eval.pbs
#
# TODO(miyabi): confirm the #PBS syntax (-q / -P / -l select) against the official
#               manual. As with train.pbs, pass resource values at submit time via -v / qsub args.
# =============================================================================

#PBS -N lerobot_eval
#PBS -j oe
# TODO(miyabi): placeholders. Submit example is the same as 03_train/train.pbs:
#   qsub -q "$QUEUE_NAME" -P "$GROUP" -l select=1:ngpus=1 \
#        -l walltime="$WALLTIME" -v ALL 04_eval/eval.pbs

set -euo pipefail
cd "${PBS_O_WORKDIR:-$(pwd)}"

if [[ -f config.env ]]; then
  # shellcheck disable=SC1091
  source config.env
fi

# --- fail-fast ---
: "${APPTAINER_IMAGE:?APPTAINER_IMAGE unset (config.env)}"
: "${OUTPUT_DIR:?OUTPUT_DIR unset}"
: "${HF_HOME:?HF_HOME unset}"

mkdir -p "${OUTPUT_DIR}"

# Environment for the offline compute node
export HF_HUB_OFFLINE=1
export HF_HOME

if [[ -n "${APPTAINER_MODULE:-}" && "${APPTAINER_MODULE}" != "<"* ]]; then
  module load "${APPTAINER_MODULE}"
fi

apptainer exec --nv \
  --bind "${OUTPUT_DIR}:${OUTPUT_DIR}" \
  --bind "${HF_HOME}:${HF_HOME}" \
  --env HF_HUB_OFFLINE=1 \
  --env "HF_HOME=${HF_HOME}" \
  "${APPTAINER_IMAGE}" \
  bash 04_eval/eval.sh
